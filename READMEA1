# PSEUDOCODE

Algorithm SwappingCouples(row)

n <- length(row)

Create array position[0 … n-1]

 # Store the index of each person
 for i <- 0 to n - 1 do
  position[row[i]] <- i
 end for

swaps <- 0

 # Process seats in pairs
 for i <- 0 to n - 1 step 2 do

   partner <- row[i] XOR 1

if row[i + 1] =! partner then

          partner_pos <- position[partner]
          wrong_person <- row[i + 1]

         # Swap them
         row[i + 1] <-> row[partner_pos]

         # Update positions
           position[wrong_person] <- partner_pos
           position[partner] <- i + 1

         swaps <- swaps + 1

      end if

  end for

  return swaps

