# PSEUDOCODE

Algorithm PreferredStartingCity(distances, fuel, mpg)

 n <- length(distances)

  start <- 0
  tank <- 0

 for i <- 0 to n − 1 do

      gain <- fuel[i] * mpg - distances[i]

      tank <- tank += gain

  if tank < 0 then
       start <- i + 1
       tank <- 0
 end if

 end for

 return start

End Algorithm

Algorithm Main

  city_distances <- [5, 25, 15, 10, 15]
  fuel <- [1, 2, 1, 0, 3]
  mpg <- 10

  result <- PreferredStartingCity(city_distances, fuel, mpg)

  Output "The preferred starting city is:", result

End Main


